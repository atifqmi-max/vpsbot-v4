########################################
# StoneNodes VPS Manager Bot — Config
# Copy this file to ".env" and fill in your own values.
# Never commit your real ".env" to GitHub.
########################################

# ── Discord Bot ───────────────────────────────────────
# Discord Developer Portal -> Your App -> Bot -> Token
DISCORD_TOKEN=

# Role ID that is allowed to run admin commands (right-click role -> Copy ID)
ADMIN_ROLE_ID=0

# Comma separated Discord user IDs that always count as admins
# Example: ADMIN_USER_IDS=123456789012345678,987654321098765432
ADMIN_USER_IDS=

# ── Public Server Info ────────────────────────────────
# The public IPv4 of the machine this bot runs on.
# This is what gets shown to users as "Shared IPv4" and is
# what their SSH command will actually connect to.
SERVER_IP=127.0.0.1

# Range of host ports to hand out for direct root SSH access.
# Each VPS gets one unique port from this range, forwarded to
# its container's internal port 22. Make sure this range is
# open in your firewall / cloud provider's security group.
SSH_PORT_START=20000
SSH_PORT_END=29999

# Port the built-in node-agent WebSocket server listens on.
# Remote "node" servers connect OUTBOUND to this port.
# Open it in your firewall the same way as the SSH port range.
AGENT_PORT=8788

# ── Pterodactyl (optional) ────────────────────────────
# Leave blank if you are not integrating with a Pterodactyl panel.
PTERO_URL=
PTERO_API_KEY=
